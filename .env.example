# LLM providers are configured in data/{agent_id}/config.json
# See docs/providers.md for setup (Vertex, OpenAI, OpenAI-compatible)
#
# The LLM_* env vars below are LEGACY — they still work (auto-migrated
# to a default openai-compat provider) but config.json is recommended.
# LLM_URL=http://localhost:4000/v1/chat/completions
# LLM_MODEL=gemini-2.5-flash
# LLM_API_KEY=dummy

# Mattermost settings (leave empty for interactive terminal mode)
MATTERMOST_URL=https://comms.example.com
MATTERMOST_TOKEN=your-bot-token
MATTERMOST_BOT_USERNAME=decafclaw

# Tabstack settings
TABSTACK_API_KEY=your-tabstack-api-key
# TABSTACK_API_URL=https://api.tabstack.ai  # default; override for dev/stage

# Vertex AI (if using ADC with a service account file)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Agent settings
# SYSTEM_PROMPT=You are a helpful assistant.
# MAX_TOOL_ITERATIONS=10
